---
const { active = "about", onSelect } = Astro.props;
const navItems = [
  { label: "about", href: "/", key: "about" },
  { label: "writing", href: "/writing", key: "writing" },
  { label: "stack", href: "/stack", key: "stack" },
  { label: "contact", href: "/contact", key: "contact" },
];
---

<div
  class="mt-6 mb-6 text-xl text-center whitespace-nowrap font-sans flex flex-wrap justify-center gap-x-2 gap-y-2 sm:gap-x-4"
>
  {
    navItems.map(({ label, href, key }) => (
      <a
        href={href}
        class={[
          "px-2 py-1 transition-colors",
          "text-base sm:text-xl",
          active === key
            ? "text-stone-300"
            : "text-zinc-500 hover:text-stone-300",
        ].join(" ")}
      >
        {label}
      </a>
    ))
  }
</div>

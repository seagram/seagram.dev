---
import { Icon } from "astro-icon/components";

const iconNames = [
  "aws",
  "postgres",
  "kubernetes",
  "ansible",
  "terraform",
  "jenkins",
];
---

<div class="flex justify-center items-center space-x-4">
  {
    iconNames.map((name) => (
      <Icon name={name} class="h-12 w-12 md:h-14 md:w-14" />
    ))
  }
</div>
